<Window x:Class="MdTranslatorViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        x:Name="RootWindow"
        mc:Ignorable="d"
        Title="MD Translator Viewer"
        Icon="AppIcon.ico"
        Width="1440"
        Height="920"
        MinWidth="860"
        MinHeight="760"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="Window_OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#181818" />
        <SolidColorBrush x:Key="ContentBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="LineBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="WindowFrameBrush" Color="#802B2B2B" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="StrongTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9D9D9D" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#989898" />
        <SolidColorBrush x:Key="StatusTextBrush" Color="#9DA5B4" />
        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="MenuBorderBrush" Color="#343434" />
        <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#343434" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#E6E6E6" />
        <SolidColorBrush x:Key="MenuHighlightBrush" Color="#2A2D2E" />
        <SolidColorBrush x:Key="MenuHighlightForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="#181818" />
        <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="TabBorderBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TabInactiveForegroundBrush" Color="#9D9D9D" />
        <SolidColorBrush x:Key="TabActiveForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TabAccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="ToggleTrackBrush" Color="#313131" />
        <SolidColorBrush x:Key="ToggleTrackBorderBrush" Color="#3C3C3C" />
        <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4DAAFC" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#822489DB" />
        <SolidColorBrush x:Key="WindowControlForegroundBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="LoadingOverlayBrush" Color="#B8181818" />
        <SolidColorBrush x:Key="DropOverlayBrush" Color="#78101214" />
        <SolidColorBrush x:Key="DropPillBrush" Color="#F4181818" />
        <SolidColorBrush x:Key="DropPillBorderBrush" Color="#6A79C6FF" />
        <SolidColorBrush x:Key="DropPillTitleBrush" Color="#F2FFFFFF" />
        <SolidColorBrush x:Key="DropPillCopyBrush" Color="#9FA9B8" />
        <SolidColorBrush x:Key="DropPillDotBrush" Color="#6A79C6FF" />
        <SolidColorBrush x:Key="TabScrollThumbBrush" Color="#66CCCCCC" />
        <SolidColorBrush x:Key="TabScrollThumbHoverBrush" Color="#99FFFFFF" />

        <Style x:Key="ChromeRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuScrollPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuScrollLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="ButtonBorder"
                                Margin="0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <TextBlock x:Name="Glyph"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="8"
                                       Foreground="{TemplateBinding Foreground}"
                                       Opacity="0.62"
                                       Text="&#xE70E;" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="down">
                                <Setter TargetName="Glyph" Property="Text" Value="&#xE70D;" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource ControlHoverBrush}" />
                                <Setter TargetName="Glyph" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource MenuHighlightBrush}" />
                                <Setter TargetName="Glyph"
                                        Property="Foreground"
                                        Value="{DynamicResource MenuHighlightForegroundBrush}" />
                                <Setter TargetName="Glyph" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Width="8" Background="Transparent">
                            <Border x:Name="ThumbBorder"
                                    Width="3"
                                    Margin="0"
                                    HorizontalAlignment="Center"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="0"
                                    Opacity="0.38" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Width" Value="4" />
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.68" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Width" Value="4" />
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.86" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root"
                              Width="{TemplateBinding Width}"
                              Margin="1,2,0,2"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                                  Style="{StaticResource MenuScrollPageButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MenuScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                                  Style="{StaticResource MenuScrollPageButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="Root" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource TabScrollThumbBrush}" />
            <Setter Property="Height" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Background"
                                        Value="{DynamicResource TabScrollThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Background"
                                        Value="{DynamicResource TabScrollThumbHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Height" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource ChromeRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TopTabScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Style="{StaticResource ChromeRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic, Apple SD Gothic Neo" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          MaxHeight="420"
                                          Padding="{TemplateBinding Padding}">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource MenuScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabContextMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="10,6"
                                Background="{DynamicResource MenuSeparatorBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic, Apple SD Gothic Neo" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Margin="1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              Margin="10,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuHighlightBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource MenuHighlightForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource MenuHighlightBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource MenuHighlightForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Foreground" Value="{DynamicResource TabInactiveForegroundBrush}" />
            <Setter Property="ToolTip" Value="{Binding FilePath}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu Style="{StaticResource TabContextMenuStyle}"
                                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Close Tab"
                                  Style="{StaticResource TabContextMenuItemStyle}"
                                  Tag="close-tab" />
                        <Separator Style="{StaticResource TabContextMenuSeparatorStyle}" />
                        <MenuItem Header="Copy Path"
                                  Style="{StaticResource TabContextMenuItemStyle}"
                                  Tag="copy-path" />
                        <MenuItem Header="Reveal In File Explorer"
                                  Style="{StaticResource TabContextMenuItemStyle}"
                                  Tag="reveal-in-file-explorer" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder"
                                Padding="0"
                                Background="{DynamicResource TabInactiveBackgroundBrush}"
                                BorderBrush="{DynamicResource TabBorderBrush}"
                                BorderThickness="1,0,1,0"
                                CornerRadius="9,9,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border x:Name="TabAccent"
                                        Grid.Row="0"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <ContentPresenter Grid.Row="1"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TabActiveForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabActiveBackgroundBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource TabActiveBackgroundBrush}" />
                                <Setter TargetName="TabAccent" Property="Background" Value="{DynamicResource TabAccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TabActiveForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseRightButtonDown"
                         Handler="DocumentTabItem_OnPreviewMouseRightButtonDown" />
            <EventSetter Event="RequestBringIntoView"
                         Handler="DocumentTabItem_OnRequestBringIntoView" />
            <EventSetter Event="ContextMenuOpening"
                         Handler="DocumentTabItem_OnContextMenuOpening" />
        </Style>

        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource StrongTextBrush}" />
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TranslateButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="136" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter VerticalAlignment="Center" />

                            <Border Grid.Column="2"
                                    x:Name="SwitchTrack"
                                    Width="42"
                                    Height="24"
                                    Background="{DynamicResource ToggleTrackBrush}"
                                    BorderBrush="{DynamicResource ToggleTrackBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Ellipse x:Name="SwitchThumb"
                                             Width="18"
                                             Height="18"
                                             Margin="3,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource ToggleThumbBrush}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource StrongTextBrush}" />
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentStrongBrush}" />
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="{DynamicResource StrongTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="{DynamicResource WindowControlForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource MenuHighlightBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverflowButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Foreground" Value="{DynamicResource WindowControlForegroundBrush}" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="OverflowMenuStyle"
               TargetType="ContextMenu"
               BasedOn="{StaticResource TabContextMenuStyle}" />

        <Style x:Key="OverflowSeparatorStyle"
               TargetType="Separator"
               BasedOn="{StaticResource TabContextMenuSeparatorStyle}" />

        <Style x:Key="OverflowMenuItemStyle"
               TargetType="MenuItem"
               BasedOn="{StaticResource TabContextMenuItemStyle}">
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
        </Style>

    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border x:Name="WindowContentHost"
                Background="{DynamicResource AppBackgroundBrush}"
                CornerRadius="10">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="40" />
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="5"
                Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="0,14,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                    <Border Width="36"
                            Height="36"
                            Margin="0,0,0,24"
                            Background="Transparent">
                        <Image Source="logo.png"
                               Stretch="Uniform" />
                    </Border>
                    <Button Style="{StaticResource RailButtonStyle}"
                            ToolTip="Open file"
                            Content="&#xE8E5;"
                            Click="OpenFileButton_OnClick" />
                    <Button Style="{StaticResource RailButtonStyle}"
                            ToolTip="Reload"
                            Content="&#xE72C;"
                            Click="RefreshButton_OnClick" />
                </StackPanel>

                <Button Grid.Row="1"
                        x:Name="SettingsButton"
                        Style="{StaticResource RailButtonStyle}"
                        Width="46"
                        Height="46"
                        Margin="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        FontSize="17"
                        ToolTip="Settings"
                        Content="&#xE713;"
                        Click="SettingsButton_OnClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SettingsMenu"
                                     Style="{StaticResource OverflowMenuStyle}"
                                     Opened="SettingsMenu_OnOpened">
                            <MenuItem x:Name="AdaptiveTabWidthMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Tabs resize with the window width"
                                      Click="AdaptiveTabWidthMenuItem_OnClick" />
                            <MenuItem x:Name="SizeToTitleTabWidthMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Tabs keep their own widths and scroll horizontally when needed"
                                      Click="SizeToTitleTabWidthMenuItem_OnClick" />
                            <Separator Style="{StaticResource OverflowSeparatorStyle}" />
                            <MenuItem x:Name="DarkModernThemeMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Dark Modern editor colors"
                                      Click="DarkModernThemeMenuItem_OnClick" />
                            <MenuItem x:Name="DarkPlusThemeMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Dark+ editor colors"
                                      Click="DarkPlusThemeMenuItem_OnClick" />
                            <MenuItem x:Name="LightModernThemeMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Light Modern editor colors"
                                      Click="LightModernThemeMenuItem_OnClick" />
                            <MenuItem x:Name="LightPlusThemeMenuItem"
                                      Style="{StaticResource OverflowMenuItemStyle}"
                                      ToolTip="Light+ editor colors"
                                      Click="LightPlusThemeMenuItem_OnClick" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                PreviewMouseLeftButtonDown="TitleBar_OnPreviewMouseLeftButtonDown"
                PreviewMouseMove="TitleBar_OnPreviewMouseMove"
                PreviewMouseLeftButtonUp="TitleBar_OnPreviewMouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="10,0,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="GoBackButton"
                            Style="{StaticResource NavigationButtonStyle}"
                            Margin="0,0,4,0"
                            ToolTip="Go back"
                            Content="&#xE72B;"
                            IsEnabled="{Binding ElementName=RootWindow, Path=CanNavigateBack}"
                            Click="GoBackButton_OnClick" />
                    <Button x:Name="GoForwardButton"
                            Style="{StaticResource NavigationButtonStyle}"
                            ToolTip="Go forward"
                            Content="&#xE72A;"
                            IsEnabled="{Binding ElementName=RootWindow, Path=CanNavigateForward}"
                            Click="GoForwardButton_OnClick" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="Transparent" />

                <Border Grid.Column="2"
                        Width="24"
                        Background="Transparent" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Content="&#xE921;"
                            Click="MinimizeButton_OnClick" />
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Content="&#xE922;"
                            Click="MaximizeRestoreButton_OnClick" />
                    <Button Style="{StaticResource CloseWindowControlButtonStyle}"
                            Content="&#xE8BB;"
                            Click="CloseWindowButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                PreviewMouseLeftButtonDown="TitleBar_OnPreviewMouseLeftButtonDown"
                PreviewMouseMove="TitleBar_OnPreviewMouseMove"
                PreviewMouseLeftButtonUp="TitleBar_OnPreviewMouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="24" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="TabsInteractionHost"
                      Grid.Column="0"
                      Background="Transparent"
                      MouseEnter="TabsInteractionHost_OnMouseEnter"
                      MouseLeave="TabsInteractionHost_OnMouseLeave"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="NoTabsText"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Open a Markdown file"
                               IsHitTestVisible="False" />

                    <ScrollViewer x:Name="TabsScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  CanContentScroll="False"
                                  PreviewMouseWheel="TabsScrollViewer_OnPreviewMouseWheel"
                                  ScrollChanged="TabsScrollViewer_OnScrollChanged"
                                  SizeChanged="TabsScrollViewer_OnSizeChanged"
                                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <ListBox x:Name="DocumentTabsList"
                                 AllowDrop="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding OpenDocuments, ElementName=RootWindow}"
                                 SelectedItem="{Binding SelectedDocument, ElementName=RootWindow, Mode=OneWay}"
                                 SelectionChanged="DocumentTabsList_OnSelectionChanged"
                                 PreviewMouseLeftButtonDown="DocumentTabsList_OnPreviewMouseLeftButtonDown"
                                 PreviewMouseLeftButtonUp="DocumentTabsList_OnPreviewMouseLeftButtonUp"
                                 PreviewMouseDown="DocumentTabsList_OnPreviewMouseDown"
                                 PreviewMouseMove="DocumentTabsList_OnPreviewMouseMove"
                                 DragOver="DocumentTabsList_OnDragOver"
                                 Drop="DocumentTabsList_OnDrop"
                                 shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                 ItemContainerStyle="{StaticResource TopTabItemStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding ElementName=RootWindow, Path=TabItemWidth}"
                                            MinWidth="{Binding ElementName=RootWindow, Path=TabItemMinWidth}"
                                            MaxWidth="{Binding ElementName=RootWindow, Path=TabItemMaxWidth}"
                                            Padding="10,4,8,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Margin="0,2,4,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                       Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource TabCloseButtonStyle}"
                                                    Content="x"
                                                    Visibility="{Binding ElementName=RootWindow, Path=TabCloseButtonVisibility}"
                                                    Tag="{Binding}"
                                                    Click="CloseTabButton_OnClick" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border x:Name="TabsScrollIndicatorHost"
                            Margin="14,0,14,-5"
                            VerticalAlignment="Bottom"
                            Opacity="0"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            PreviewMouseWheel="TabsScrollIndicatorHost_OnPreviewMouseWheel"
                            Panel.ZIndex="5"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <ScrollBar x:Name="TabsScrollIndicator"
                                   Style="{StaticResource TopTabScrollBarStyle}"
                                   Orientation="Horizontal"
                                   SmallChange="72"
                                   ValueChanged="TabsScrollIndicator_OnValueChanged"
                                   shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    </Border>
                </Grid>

                <Button x:Name="OverflowTabsButton"
                        Grid.Column="1"
                        Style="{StaticResource OverflowButtonStyle}"
                        Content="&#xE70D;"
                        Visibility="Hidden"
                        ToolTip="Show tabs"
                        Click="OverflowTabsButton_OnClick">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="TabOverflowMenu"
                                     Style="{StaticResource OverflowMenuStyle}" />
                    </Button.ContextMenu>
                </Button>

                <Border Grid.Column="2"
                        Width="24"
                        Background="Transparent" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{DynamicResource ContentBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,10,28,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FilePathText"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="Open a Markdown file to start."
                           TextTrimming="CharacterEllipsis" />

                <ToggleButton x:Name="TranslateToggleButton"
                              Grid.Column="1"
                              Margin="16,0,0,0"
                              VerticalAlignment="Center"
                              Style="{StaticResource TranslateButtonStyle}"
                              Content="Translate"
                              Click="TranslateToggleButton_OnClick" />
            </Grid>
        </Border>

        <Grid Grid.Row="3"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Background="{DynamicResource ContentBrush}"
              AllowDrop="True"
              PreviewDragEnter="Window_OnPreviewDragEnter"
              PreviewDragOver="Window_OnPreviewDragOver"
              PreviewDragLeave="Window_OnPreviewDragLeave"
              PreviewDrop="Window_OnPreviewDrop">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  AllowDrop="True"
                  PreviewDragEnter="Window_OnPreviewDragEnter"
                  PreviewDragOver="Window_OnPreviewDragOver"
                  PreviewDragLeave="Window_OnPreviewDragLeave"
                  PreviewDrop="Window_OnPreviewDrop">
                <wv2:WebView2 x:Name="DocumentWebView"
                              AllowDrop="True"
                              AllowExternalDrop="True"
                              PreviewDragEnter="Window_OnPreviewDragEnter"
                              PreviewDragOver="Window_OnPreviewDragOver"
                              PreviewDragLeave="Window_OnPreviewDragLeave"
                              PreviewDrop="Window_OnPreviewDrop"
                              DefaultBackgroundColor="#1F1F1F" />

                <Border x:Name="LoadingOverlay"
                        Background="{DynamicResource LoadingOverlayBrush}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <ProgressBar Width="240"
                                     Height="8"
                                     IsIndeterminate="True" />
                        <TextBlock x:Name="LoadingText"
                                   Margin="0,16,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="14"
                                   Text="Loading..." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="4"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{DynamicResource ChromeBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="AutoReloadCheckBox"
                          VerticalAlignment="Center"
                          IsChecked="True"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          FontSize="12"
                          Content="Auto reload on save" />

                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="{DynamicResource StatusTextBrush}"
                           Text="Ready"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        </Grid>
        </Border>

        <Border x:Name="MaximizedDragStrip"
                Height="0"
                VerticalAlignment="Top"
                Background="Transparent"
                Visibility="Collapsed"
                Panel.ZIndex="20"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                PreviewMouseLeftButtonDown="TitleBar_OnPreviewMouseLeftButtonDown"
                PreviewMouseMove="TitleBar_OnPreviewMouseMove"
                PreviewMouseLeftButtonUp="TitleBar_OnPreviewMouseLeftButtonUp" />

        <Border x:Name="WindowFrameBorder"
                BorderBrush="{DynamicResource WindowFrameBrush}"
                BorderThickness="1"
                CornerRadius="10"
                SnapsToDevicePixels="True"
                IsHitTestVisible="False"
                Panel.ZIndex="40" />

        <Border x:Name="DropOverlay"
                Grid.Row="3"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0"
                Background="{DynamicResource DropOverlayBrush}"
                CornerRadius="0"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Panel.ZIndex="30">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="18,11"
                    Background="{DynamicResource DropPillBrush}"
                    BorderBrush="{DynamicResource DropPillBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="8"
                             Height="8"
                             VerticalAlignment="Center"
                             Fill="{DynamicResource DropPillDotBrush}" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DropPillTitleBrush}"
                               Text="Drop to open Markdown" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DropPillCopyBrush}"
                               Text=".md .markdown .mdx .mkd" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
